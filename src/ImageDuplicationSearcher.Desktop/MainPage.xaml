<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ImageDuplicationSearcher.Desktop.MainPage">

    <ScrollView>
        <StackLayout Padding="12" Spacing="12" Orientation="Vertical">
            <Label Text="Image Duplicate Searcher" FontSize="20" />

            <!-- Load Results Section -->
            <StackLayout Spacing="8">
                <Label Text="Load Results" FontAttributes="Bold" />
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                    <Button Grid.Column="0" Text="Open JSON Results" Clicked="OnOpenJsonResults" />
                    <Entry Grid.Column="1" x:Name="ResultsFileEntry" Placeholder="Selected results file" IsReadOnly="True" HorizontalOptions="FillAndExpand" />
                </Grid>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6" Margin="0,4">
                    <Label Grid.Column="0" Text="Status:" VerticalOptions="Center" />
                    <Label Grid.Column="1" x:Name="StatusLabel" Text="No file loaded" VerticalOptions="Center" />
                </Grid>
                <Label x:Name="ErrorLabel" TextColor="Red" IsVisible="False" LineBreakMode="WordWrap" />
            </StackLayout>

            <!-- Separator -->
            <BoxView HeightRequest="1" Color="#CCCCCC" Margin="0,8" />

            <!-- Navigation Section -->
            <StackLayout Spacing="8">
                <Label Text="Navigate Duplicate Groups" FontAttributes="Bold" />
                <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="6" Margin="0,4">
                    <Button x:Name="PrevButton" Grid.Column="0" Text="Previous" HorizontalOptions="Start" />
                    <Button x:Name="NextButton" Grid.Column="1" Text="Next" HorizontalOptions="Start" />
                    <Label x:Name="SummaryLabel" Grid.Column="2" Text="0 / 0" VerticalOptions="Center" HorizontalOptions="Start" />
                    <Label x:Name="GroupHashLabel" Grid.Column="3" Text="Hash: -" VerticalOptions="Center" HorizontalOptions="End" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6" Margin="0,4">
                    <Entry x:Name="GroupEntry" Placeholder="Group #" Keyboard="Numeric" HorizontalOptions="Start" />
                    <Button x:Name="GoButton" Text="Go" Grid.Column="1" HorizontalOptions="Start" />
                    <Label x:Name="NavErrorLabel" Grid.Column="2" TextColor="Red" IsVisible="False" VerticalOptions="Center" />
                </Grid>
            </StackLayout>

                <!-- Image Canvas Display Area -->
                <StackLayout Spacing="8">
                    <Label Text="Images in Group" FontAttributes="Bold" />
                    <Label x:Name="GroupImageCountLabel" Text="Images: 0" />

                    <!-- Responsive, scrollable grid of image tiles. ItemsSource will be bound in code-behind. -->
                    <CollectionView x:Name="ImageCollectionView" SelectionMode="None" ItemsLayout="VerticalList">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="3" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="6" Margin="6" HasShadow="False" BorderColor="#DDDDDD">
                                    <StackLayout>
                                        <Image Source="{Binding Image}" Aspect="AspectFill" HeightRequest="120" />
                                        <Label Text="{Binding Path}" LineBreakMode="TailTruncation" FontSize="12" />
                                        <Label Text="{Binding SizeMB, StringFormat='Size: {0} MB'}" FontSize="12" />
                                        <Label Text="{Binding PlaceholderReason}" TextColor="Red" FontSize="11" />
                                        <Button Text="Remove"
                                                Command="{Binding RemoveCommand}"
                                                FontSize="12"
                                                HorizontalOptions="Start"
                                                BackgroundColor="#e74c3c"
                                                TextColor="White"
                                                AutomationProperties.Name="Remove image" />
                                    </StackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </StackLayout>
        </StackLayout>
    </ScrollView>

</ContentPage>
